# Telegram Bot Token (from @BotFather) — ОПЦИОНАЛЬНО
# Если не задан, Telegram бот не запускается, работает только HTTP API
# BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated admin Telegram user IDs (нужно только если задан BOT_TOKEN)
# ADMIN_IDS=123456789,987654321

# Your VPS public IP or domain
PROXY_HOST=1.2.3.4

# MTProxy port (443 recommended to bypass firewalls)
PROXY_PORT=443

# Ad tag from @MTProxybot (promote your channel to proxy users)
# Get it: open @MTProxybot -> /newchannel -> follow steps -> copy hex tag
# Leave empty to disable ads
AD_TAG=

# Fake-TLS domain (camouflages traffic as HTTPS to this domain)
TLS_DOMAIN=www.google.com

# Secret for Redis (change this!)
REDIS_PASSWORD=changeme_redis_pass

# REST API key — передавай в заголовке X-Api-Key
API_KEY=changeme_api_key_here

# Port for the REST API (внутренний, проксируй через nginx если нужен внешний доступ)
API_PORT=8080

# Nginx webhook proxy работает на порту 80 без конфигурации доменов —
# Cloudflare терминирует SSL и шлёт HTTP на этот сервер.
# В Cloudflare выставь SSL/TLS mode = "Flexible" для домена webhook proxy.